DB_SERVER=your-azure-server.database.windows.net
DB_PORT=1433
DB_USER=your-username
DB_PASSWORD=your-password
DB_DATABASE=bztel_db
JWT_SECRET=bztel-sms-app-secret-key-12345
ADMIN_EMAIL=admin@bztel.com
ADMIN_PASSWORD=admin123
PORT=3000

# Monty Mobile SMPP Gateway Configuration
SMPP_ENABLED=false
SMPP_HOST=185.135.128.117
SMPP_PORT=7500
SMPP_SYSTEM_TYPE=SMPP

# Transactional Account
SMPP_TX_SYSTEM_ID=BZTItms
SMPP_TX_PASSWORD=your_password

# Promotional Account
SMPP_PROMO_SYSTEM_ID=BZTIPrmo
SMPP_PROMO_PASSWORD=your_password

# Comma-separated promotional sender IDs list (all caps)
SMPP_PROMO_SENDER_IDS=BZTIPRMO,BADID
