generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int                @id @default(autoincrement())
  email            String             @unique
  passwordHash     String?            @map("password_hash")
  isAdmin          Boolean            @default(false) @map("is_admin")
  status           String             @default("active")
  balance          Int                @default(10)
  role             String             @default("Owner")
  parentUserId     Int?               @map("parent_user_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  campaigns        BirthdayCampaign[]
  contacts         Contact[]
  drafts           Draft[]
  emailLogs        EmailLog[]
  senderIds        SenderId[]
  serviceRequests  ServiceRequest[]
  smsLogs          SmsLog[]
  supportTickets   SupportTicket[]
  templates        Template[]
  transactions     Transaction[]
  parentUser       User?              @relation("UserToUser", fields: [parentUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subUsers         User[]             @relation("UserToUser")
  virtualNumbers   VirtualNumber[]
  voiceLogs        VoiceLog[]
  loyaltyPoints    Int                @default(0) @map("loyalty_points")
  loyaltyLedgers   LoyaltyLedger[]

  @@map("users")
}

model Contact {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  phone     String
  groupName String   @default("Default") @map("group_name")
  birthdate String?
  createdAt DateTime @default(now()) @map("created_at")
  email     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model SmsLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  senderId   String   @map("sender_id")
  recipient  String
  message    String
  credits    Int      @default(1)
  status     String   @default("pending")
  sentAt     DateTime @default(now()) @map("sent_at")
  providerId String?  @map("provider_id")
  batchId    String?  @map("batch_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sms_logs")
}

model Template {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("templates")
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  key       String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model LoyaltyLedger {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  amount      Int
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loyalty_ledgers")
}

model Transaction {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  type          String
  amount        Int
  balanceBefore Int      @map("balance_before")
  balanceAfter  Int      @map("balance_after")
  description   String
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model BirthdayCampaign {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  senderId        String   @map("sender_id")
  targetGroup     String   @map("target_group")
  dispatchTime    String   @map("dispatch_time")
  messageTemplate String   @map("message_template")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("birthday_campaigns")
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  subject     String
  priority    String
  description String
  status      String   @default("Open")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model ServiceRequest {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  serviceType String   @map("service_type")
  repName     String   @map("rep_name")
  phone       String
  description String
  status      String   @default("Reviewing")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("service_requests")
}

model VoiceLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  senderId  String   @map("sender_id")
  recipient String
  audioUrl  String?  @map("audio_url")
  ttsText   String?  @map("tts_text")
  duration  Int      @default(0)
  credits   Int      @default(1)
  status    String   @default("pending")
  sentAt    DateTime @default(now()) @map("sent_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_logs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String
  details   String
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model VirtualNumber {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  number    String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("virtual_numbers")
}

model Draft {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  senderId   String   @map("sender_id")
  recipients String
  message    String
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("drafts")
}

model SenderId {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  name            String   @unique
  description     String
  status          String   @default("pending")
  rejectionReason String?  @map("rejection_reason")
  documentUrl     String?  @map("document_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sender_ids")
}

model EmailLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  senderName  String   @map("sender_name")
  senderEmail String   @map("sender_email")
  recipient   String
  subject     String
  bodyHtml    String?  @map("body_html")
  bodyText    String?  @map("body_text")
  credits     Int      @default(1)
  status      String   @default("pending")
  sentAt      DateTime @default(now()) @map("sent_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_logs")
}
